{
  "manifest_version": 3,
  "name": "unicode/r",
  "version": "1.0",
  "description": "Tool to convert and map text to unicode characters for quick inserts and lookups.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["aliases.js", "main.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "unicode/r",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
